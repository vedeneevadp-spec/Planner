# For desktop browser dev the local API works as-is. For Capacitor builds on an
# emulator or physical phone this must point to a reachable backend URL
# instead (for example https://chaotika.ru or Android emulator
# http://10.0.2.2:3001).
VITE_API_BASE_URL=http://127.0.0.1:3001
# Enable Chaotika email/password auth. Leave disabled for local legacy overrides.
VITE_AUTH_PROVIDER=disabled
# Optional bearer token for service-mode API development. Leave empty in normal
# browser auth.
VITE_API_ACCESS_TOKEN=
# Optional override if you want web to force a specific session instead of
# taking the default workspace membership from the API runtime.
VITE_ACTOR_USER_ID=11111111-1111-4111-8111-111111111111
VITE_WORKSPACE_ID=22222222-2222-4222-8222-222222222222
