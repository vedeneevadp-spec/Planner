API_HOST=0.0.0.0
API_PORT=3001
API_CORS_ORIGIN=http://127.0.0.1:5173
# `disabled` keeps the legacy header-based flow for local development.
# `supabase` requires `Authorization: Bearer <access-token>` on API requests.
API_AUTH_MODE=disabled
# `memory` is supported only in tests. Application runtime is Postgres-first.
API_STORAGE_DRIVER=postgres
# Optional override for Postgres RLS runtime context.
# Leave empty for auto mode: direct Postgres applies transaction-local RLS
# context; Supabase transaction pooler disables DB RLS context to avoid
# connection instability.
# Supported overrides: disabled, enabled, transaction_local, session_connection.
API_DB_RLS_MODE=
# For local Docker Postgres use the default value below.
# For managed Supabase runtime prefer the transaction pooler URL (`:6543`) when
# IPv4 compatibility is needed.
DATABASE_URL=postgres://planner:planner@127.0.0.1:54329/planner_development

# Required when API_AUTH_MODE=supabase unless SUPABASE_PROJECT_REF is present.
SUPABASE_URL=
SUPABASE_PROJECT_REF=

# Optional helpers for symmetric-key projects or auth-server fallback.
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=
