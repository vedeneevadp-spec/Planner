API_HOST=0.0.0.0
API_PORT=3001
API_CORS_ORIGIN=http://127.0.0.1:5173
# `disabled` keeps the legacy header-based flow for local development.
# `jwt` enables Chaotika email/password auth.
API_AUTH_MODE=disabled
# `memory` is supported only in tests. Application runtime is Postgres-first.
API_STORAGE_DRIVER=postgres
# Optional override for Postgres RLS runtime context.
# Leave empty for auto mode: Postgres applies transaction-local RLS context.
# Supported overrides: disabled, enabled, transaction_local, session_connection.
API_DB_RLS_MODE=
# For local Docker Postgres use the default value below.
DATABASE_URL=postgres://planner:planner@127.0.0.1:54329/planner_development

# Required when API_AUTH_MODE=jwt.
AUTH_JWT_SECRET=
AUTH_JWT_ISSUER=planner-api
AUTH_JWT_AUDIENCE=authenticated
AUTH_ACCESS_TOKEN_TTL_SECONDS=3600
AUTH_REFRESH_TOKEN_TTL_SECONDS=2592000
AUTH_PASSWORD_RESET_TTL_SECONDS=3600
AUTH_PUBLIC_APP_URL=http://127.0.0.1:5173
AUTH_EMAIL_FROM=Chaotika <no-reply@chaotika.ru>
AUTH_SMTP_HOST=
AUTH_SMTP_PORT=587
AUTH_SMTP_SECURE=false
AUTH_SMTP_USER=
AUTH_SMTP_PASSWORD=

# Optional Alice account linking and command parser.
ALICE_OAUTH_CLIENT_ID=
ALICE_OAUTH_CLIENT_SECRET=
ALICE_OAUTH_REDIRECT_URI=https://social.yandex.net/broker/redirect
ALICE_OAUTH_CODE_TTL_SECONDS=300
# Enables hybrid rules + LLM parsing for non-obvious Alice commands.
# Supported providers: yandex, openai, openai-compatible.
ALICE_LLM_PROVIDER=yandex
ALICE_LLM_API_KEY=
ALICE_LLM_YANDEX_FOLDER_ID=
# Optional explicit model override; with ALICE_LLM_YANDEX_FOLDER_ID this is built automatically.
ALICE_LLM_MODEL=
ALICE_LLM_ENDPOINT=https://ai.api.cloud.yandex.net/v1/chat/completions
ALICE_LLM_TIMEOUT_MS=2500
