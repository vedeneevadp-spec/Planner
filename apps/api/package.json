{
  "name": "@planner/api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "test:postgres": "node --import tsx --test \"src/**/*.postgres-spec.ts\"",
    "coverage": "node --import tsx --test --experimental-test-coverage --test-coverage-include=\"src/**/*.ts\" --test-coverage-exclude=\"src/**/*.test.ts\" --test-coverage-exclude=\"src/**/*.postgres-spec.ts\" \"src/**/*.test.ts\"",
    "coverage:postgres-contracts": "node --import tsx --test --experimental-test-coverage --test-coverage-include=\"src/modules/**/*.repository.postgres.ts\" --test-coverage-include=\"src/modules/**/*.repository.postgres.*.ts\" --test-coverage-exclude=\"src/**/*.test.ts\" --test-coverage-exclude=\"src/**/*.contract.ts\" --test-coverage-exclude=\"src/**/*.postgres-spec.ts\" \"src/**/*.contract.postgres-spec.ts\"",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "outbox:run": "tsx src/workers/outbox.ts",
    "task-reminders:worker": "tsx src/workers/task-reminders.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@planner/contracts": "file:../../packages/contracts",
    "fastify": "^5.8.5",
    "jose": "^6.2.2",
    "kysely": "^0.28.17",
    "nodemailer": "^8.0.7",
    "pg": "^8.20.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "openapi-types": "^12.1.3",
    "tsx": "^4.21.0"
  }
}
