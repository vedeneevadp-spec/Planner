SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_ACCESS_TOKEN=your-access-token
SUPABASE_DB_PASSWORD=your-database-password
SUPABASE_URL=https://your-project-ref.supabase.co

# Optional but recommended if you want the API runtime to verify symmetric JWTs
# or call /auth/v1/user as a fallback.
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_ANON_KEY=your-legacy-anon-key
SUPABASE_JWT_SECRET=

# Primary database URL used by migrations, seed, and admin tooling.
# Prefer the direct db.<project-ref>.supabase.co host when it is reachable from
# your network. If direct access is unavailable, point this to the same
# transaction pooler URL as SUPABASE_RUNTIME_DATABASE_URL.
SUPABASE_DB_URL=postgresql://postgres.your-project-ref:__SUPABASE_DB_PASSWORD__@db.your-project-ref.supabase.co:5432/postgres?sslmode=require

# Preferred runtime connection for the backend.
# Supabase recommends the transaction pooler for stateless API workloads.
SUPABASE_RUNTIME_DATABASE_URL=postgresql://postgres.your-project-ref:__SUPABASE_DB_PASSWORD__@aws-0-your-region.pooler.supabase.com:6543/postgres?sslmode=require

# Backward-compatible alias. Keep it empty for new setups unless an older local
# script still references it directly.
SUPABASE_SESSION_POOLER_URL=
