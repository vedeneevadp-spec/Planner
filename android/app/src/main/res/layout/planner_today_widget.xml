<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/planner_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/planner_widget_background_85"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:id="@+id/planner_widget_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="10dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/planner_widget_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:singleLine="true"
                android:text="@string/planner_today_widget_title"
                android:textColor="@color/planner_widget_text"
                android:textSize="21sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/planner_widget_date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:singleLine="true"
                android:text="@string/planner_widget_preview_date"
                android:textColor="@color/planner_widget_text_soft"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/planner_widget_add_button"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@drawable/planner_widget_control_background"
                android:contentDescription="@string/planner_widget_add_task_content_description"
                android:padding="9dp"
                android:scaleType="center"
                android:src="@drawable/planner_widget_icon_add" />

            <ImageButton
                android:id="@+id/planner_widget_settings_button"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/planner_widget_control_background"
                android:contentDescription="@string/planner_widget_settings_button_content_description"
                android:padding="9dp"
                android:scaleType="center"
                android:src="@drawable/planner_widget_icon_settings" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/planner_widget_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:ellipsize="end"
        android:singleLine="true"
        android:text="@string/planner_widget_no_snapshot_summary"
        android:textColor="@color/planner_widget_text_soft"
        android:textSize="15sp" />

    <ProgressBar
        android:id="@+id/planner_widget_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="7dp"
        android:layout_marginTop="8dp"
        android:indeterminate="false"
        android:max="100"
        android:progress="0"
        android:progressDrawable="@drawable/planner_widget_progress" />

    <TextView
        android:id="@+id/planner_widget_task_1"
        style="@style/PlannerWidgetTaskText"
        android:layout_marginTop="12dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/planner_widget_task_2"
        style="@style/PlannerWidgetTaskText"
        android:visibility="gone" />

    <TextView
        android:id="@+id/planner_widget_task_3"
        style="@style/PlannerWidgetTaskText"
        android:visibility="gone" />

    <TextView
        android:id="@+id/planner_widget_task_4"
        style="@style/PlannerWidgetTaskText"
        android:visibility="gone" />

    <TextView
        android:id="@+id/planner_widget_task_5"
        style="@style/PlannerWidgetTaskText"
        android:visibility="gone" />

    <TextView
        android:id="@+id/planner_widget_task_6"
        style="@style/PlannerWidgetTaskText"
        android:visibility="gone" />

    <TextView
        android:id="@+id/planner_widget_task_7"
        style="@style/PlannerWidgetTaskText"
        android:visibility="gone" />

    <TextView
        android:id="@+id/planner_widget_task_8"
        style="@style/PlannerWidgetTaskText"
        android:visibility="gone" />

    <TextView
        android:id="@+id/planner_widget_task_9"
        style="@style/PlannerWidgetTaskText"
        android:visibility="gone" />

    <TextView
        android:id="@+id/planner_widget_task_10"
        style="@style/PlannerWidgetTaskText"
        android:visibility="gone" />

    <TextView
        android:id="@+id/planner_widget_task_11"
        style="@style/PlannerWidgetTaskText"
        android:visibility="gone" />

    <TextView
        android:id="@+id/planner_widget_task_12"
        style="@style/PlannerWidgetTaskText"
        android:visibility="gone" />

    <TextView
        android:id="@+id/planner_widget_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="9dp"
        android:ellipsize="end"
        android:singleLine="true"
        android:text="@string/planner_widget_no_snapshot_empty"
        android:textColor="@color/planner_widget_text_soft"
        android:textSize="15sp" />
</LinearLayout>
