{
  "name": "planner",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=24.14.0 <25"
  },
  "scripts": {
    "start": "vite --config apps/web/vite.config.ts",
    "dev": "vite --config apps/web/vite.config.ts",
    "dev:supabase": "node --env-file=.env.supabase.local ./scripts/dev-supabase.mjs",
    "dev:api": "npm run -w apps/api dev",
    "dev:api:postgres": "API_STORAGE_DRIVER=postgres DATABASE_URL=postgres://planner:planner@127.0.0.1:54329/planner_development npm run -w apps/api dev",
    "dev:api:supabase": "node --env-file=.env.supabase.local ./scripts/api-supabase.mjs dev",
    "start:api": "npm run -w apps/api start",
    "start:api:postgres": "API_STORAGE_DRIVER=postgres DATABASE_URL=postgres://planner:planner@127.0.0.1:54329/planner_development npm run -w apps/api start",
    "start:api:supabase": "node --env-file=.env.supabase.local ./scripts/api-supabase.mjs start",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:status": "docker compose ps postgres",
    "db:logs": "docker compose logs -f postgres",
    "db:migrate": "node ./scripts/db-migrate.mjs",
    "db:seed": "node ./scripts/db-seed.mjs",
    "db:setup": "npm run db:up && npm run db:migrate && npm run db:seed",
    "db:migrate:supabase": "node --env-file=.env.supabase.local ./scripts/db-migrate-supabase.mjs",
    "db:push:supabase": "node --env-file=.env.supabase.local ./scripts/supabase-db-push.mjs",
    "db:seed:supabase": "node --env-file=.env.supabase.local ./scripts/db-seed-supabase.mjs",
    "db:setup:supabase": "npm run db:migrate:supabase && npm run db:seed:supabase",
    "supabase:login": "node --env-file=.env.supabase.local ./scripts/supabase-login.mjs",
    "supabase:link": "node --env-file=.env.supabase.local ./scripts/supabase-link.mjs",
    "typecheck:web": "tsc --noEmit -p apps/web/tsconfig.json",
    "typecheck:contracts": "tsc --noEmit -p packages/contracts/tsconfig.json",
    "typecheck:api": "tsc --noEmit -p apps/api/tsconfig.json",
    "typecheck": "npm run typecheck:web && npm run typecheck:contracts && npm run typecheck:api",
    "build": "npm run typecheck:web && vite build --config apps/web/vite.config.ts",
    "preview": "vite preview --config apps/web/vite.config.ts",
    "mobile:sync": "npm run build && npx cap sync",
    "mobile:sync:ios": "npm run build && npx cap sync ios",
    "mobile:sync:android": "npm run build && npx cap sync android",
    "mobile:assets": "npx @capacitor/assets generate --assetPath assets --iconBackgroundColor '#f7f2e8' --splashBackgroundColor '#f7f2e8' --ios --android",
    "mobile:open:ios": "npx cap open ios",
    "mobile:open:android": "npx cap open android",
    "mobile:doctor": "npx cap doctor",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "npm run test:web",
    "test:web": "vitest --config apps/web/vite.config.ts",
    "test:web:run": "vitest run --config apps/web/vite.config.ts",
    "test:api": "npm run -w apps/api test",
    "test:run": "npm run test:web:run && npm run test:api",
    "coverage": "node ./scripts/coverage.mjs --config apps/web/vite.config.ts",
    "check": "npm run lint && npm run typecheck && npm run test:run",
    "ci": "npm run check && npm run build",
    "prepare": "husky",
    "outbox:run": "npm run -w apps/api outbox:run",
    "deploy:prod": "node ./scripts/deploy-prod.mjs"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,tsx}": [
      "eslint --fix"
    ],
    "*.{css,html,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@capacitor/core": "^8.3.1",
    "@supabase/supabase-js": "^2.103.3",
    "@tanstack/react-query": "^5.99.0",
    "dexie": "^4.4.2",
    "lottie-web": "^5.13.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@eslint/js": "^9.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "4.1.4",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.3.0",
    "fake-indexeddb": "^6.2.5",
    "globals": "17.5.0",
    "husky": "^9.1.7",
    "jsdom": "^27.0.1",
    "lint-staged": "^16.2.4",
    "prettier": "3.8.3",
    "supabase": "^2.91.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "8.58.2",
    "vite": "8.0.8",
    "vitest": "^4.0.7"
  }
}
