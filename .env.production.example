NODE_ENV=production

# API runtime. On a VPS behind Caddy, keep the API private on localhost.
API_AUTH_MODE=supabase
API_STORAGE_DRIVER=postgres
API_DB_RLS_MODE=disabled
API_HOST=127.0.0.1
API_PORT=3001
API_CORS_ORIGIN=https://chaotika.ru,https://localhost,capacitor://localhost
API_ICON_ASSET_DIR=/var/lib/planner/icon-assets

# Runtime database connection. For the current Supabase-based deployment,
# paste the resolved SUPABASE_RUNTIME_DATABASE_URL value here.
DATABASE_URL=postgresql://postgres.project-ref:password@aws-0-region.pooler.supabase.com:6543/postgres?sslmode=require

# Supabase Auth verification used by the API.
SUPABASE_URL=https://project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_JWT_SECRET=
