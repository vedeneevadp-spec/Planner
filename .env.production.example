NODE_ENV=production

# API runtime. On a VPS behind Caddy, keep the API private on localhost.
API_AUTH_MODE=jwt
API_STORAGE_DRIVER=postgres
API_DB_RLS_MODE=transaction_local
API_TRUST_PROXY_HOPS=1
API_TASK_REMINDERS_RUNTIME=worker
API_HOST=127.0.0.1
API_PORT=3001
API_CORS_ORIGIN=https://chaotika.ru,https://localhost,capacitor://localhost
API_ICON_ASSET_DIR=/var/lib/planner/icon-assets

# Runtime database connection. Production uses Timeweb Managed PostgreSQL.
# Public database access must be protected by a Timeweb firewall rule allowing
# TCP 5432 only from the production VPS IP.
DATABASE_URL=postgresql://gen_user:password@timeweb-postgres-host:5432/default_db?sslmode=require&uselibpqcompat=true

# Chaotika Auth. Generate a long random AUTH_JWT_SECRET and configure SMTP
# before enabling password reset in production.
AUTH_JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars
AUTH_JWT_ISSUER=planner-api
AUTH_JWT_AUDIENCE=authenticated
AUTH_ACCESS_TOKEN_TTL_SECONDS=3600
AUTH_REFRESH_TOKEN_TTL_SECONDS=2592000
AUTH_PASSWORD_RESET_TTL_SECONDS=3600
AUTH_PUBLIC_APP_URL=https://chaotika.ru
AUTH_EMAIL_FROM=Chaotika <no-reply@chaotika.ru>
AUTH_SMTP_HOST=smtp.example.com
AUTH_SMTP_PORT=587
AUTH_SMTP_SECURE=false
AUTH_SMTP_USER=
AUTH_SMTP_PASSWORD=

# Alice skill account linking. Use these URLs in Yandex Dialogs:
# Authorization URL: https://chaotika.ru/api/v1/oauth/alice/authorize
# Token URL: https://chaotika.ru/api/v1/oauth/alice/token
ALICE_OAUTH_CLIENT_ID=alice-skill-client-id
ALICE_OAUTH_CLIENT_SECRET=replace_with_a_long_random_alice_oauth_secret
ALICE_OAUTH_REDIRECT_URI=https://social.yandex.net/broker/redirect
ALICE_OAUTH_CODE_TTL_SECONDS=300

# Web build mode used by deploy-prod.mjs.
WEB_AUTH_PROVIDER=planner

# Android push notifications (FCM). Use either a service account file path
# or the explicit FIREBASE_* trio below.
FIREBASE_SERVICE_ACCOUNT_PATH=/etc/planner/firebase-service-account.json
# FIREBASE_PROJECT_ID=planner-mobile
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@planner-mobile.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
