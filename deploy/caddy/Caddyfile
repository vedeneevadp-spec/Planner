# Production domain for Planner.
chaotika.ru {
  encode gzip zstd
  root * /opt/planner/current/apps/web/dist

  handle /api/* {
    reverse_proxy 127.0.0.1:3001
  }

  handle /.well-known/oauth-authorization-server {
    reverse_proxy 127.0.0.1:3001
  }

  handle /.well-known/oauth-protected-resource {
    reverse_proxy 127.0.0.1:3001
  }

  handle /mcp {
    reverse_proxy 127.0.0.1:3001
  }

  handle /oauth/* {
    reverse_proxy 127.0.0.1:3001
  }

  handle /docs/mcp-haotika {
    reverse_proxy 127.0.0.1:3001
  }

  handle {
    try_files {path} /index.html
    file_server
  }

  @oauth_flow path /oauth/*
  header @oauth_flow {
    Content-Security-Policy "default-src 'self'; base-uri 'self'; connect-src 'self'; font-src 'self' data:; form-action 'self' https://social.yandex.net https://social.yandex.ru https://chatgpt.com; navigate-to 'self' https://chatgpt.com; frame-ancestors 'none'; img-src 'self' data: blob:; object-src 'none'; script-src 'self'; style-src 'self' 'unsafe-inline'"
  }

  @not_oauth_flow {
    not path /oauth/*
  }
  header @not_oauth_flow {
    Content-Security-Policy "default-src 'self'; base-uri 'self'; connect-src 'self'; font-src 'self' data:; form-action 'self' https://social.yandex.net https://social.yandex.ru; frame-ancestors 'none'; img-src 'self' data: blob:; object-src 'none'; script-src 'self'; style-src 'self' 'unsafe-inline'"
  }

  header {
    Permissions-Policy "camera=(), microphone=(self), geolocation=()"
    X-Content-Type-Options nosniff
    X-Frame-Options DENY
    Referrer-Policy strict-origin-when-cross-origin
    Strict-Transport-Security "max-age=31536000; includeSubDomains"
  }
}
